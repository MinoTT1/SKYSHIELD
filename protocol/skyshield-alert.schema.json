{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skyshield.local/protocol/skyshield-alert.schema.json",
  "title": "SKYSHIELD Alert",
  "description": "Normalized tactical drone alert payload for SKYSHIELD MVP transport.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "alert_id",
    "timestamp",
    "source",
    "threat_type",
    "risk_level",
    "confidence",
    "band",
    "distance_category",
    "vibration_pattern"
  ],
  "properties": {
    "alert_id": {
      "type": "string",
      "description": "Unique alert identifier generated by the bridge or upstream detector.",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "UTC timestamp when the alert was generated or normalized."
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "mode"
      ],
      "properties": {
        "system": {
          "type": "string",
          "description": "Alert source system name, such as simulator, Chuyka, Tsukorok, SkyDroid, or custom detector."
        },
        "mode": {
          "type": "string",
          "enum": [
            "simulated",
            "detector",
            "manual"
          ]
        },
        "device_id": {
          "type": "string",
          "description": "Optional detector or bridge device identifier."
        }
      }
    },
    "threat_type": {
      "type": "string",
      "enum": [
        "fpv",
        "dji",
        "unknown",
        "fixed_wing",
        "multirotor"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Normalized confidence score from 0.0 to 1.0."
    },
    "band": {
      "type": "string",
      "enum": [
        "unknown",
        "433MHz",
        "868MHz",
        "915MHz",
        "1.2GHz",
        "2.4GHz",
        "5.8GHz",
        "multi"
      ]
    },
    "distance_category": {
      "type": "string",
      "enum": [
        "unknown",
        "far",
        "medium",
        "near"
      ]
    },
    "vibration_pattern": {
      "type": "string",
      "enum": [
        "single_short",
        "double_short",
        "triple_short",
        "long_pulse",
        "repeat_urgent"
      ]
    },
    "display_message": {
      "type": "string",
      "maxLength": 80,
      "description": "Short watch-safe alert message."
    },
    "recommended_action": {
      "type": "string",
      "maxLength": 120,
      "description": "Short operator-facing action hint."
    },
    "expires_in_ms": {
      "type": "integer",
      "minimum": 1000,
      "description": "Suggested alert lifetime from receipt time."
    },
    "metadata": {
      "type": "object",
      "description": "Optional detector-specific details retained for debugging or future adapters.",
      "additionalProperties": true
    }
  }
}
