{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://skyshield.local/protocol/skyshield-alert.schema.json",
  "title": "SKYSHIELD BLE Alert Packet",
  "description": "Canonical compact SKYSHIELD alert packet shared by ESP32 bridge and Garmin app.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "threat",
    "severity",
    "band",
    "distance",
    "confidence"
  ],
  "properties": {
    "threat": {
      "type": "string",
      "enum": [
        "FPV",
        "DJI",
        "UNKNOWN"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "band": {
      "type": "string",
      "enum": [
        "1.2GHz",
        "2.4GHz",
        "3.3GHz",
        "5.8GHz",
        "MULTI"
      ]
    },
    "distance": {
      "type": "string",
      "enum": [
        "FAR",
        "MID",
        "NEAR"
      ]
    },
    "direction": {
      "type": "string",
      "enum": [
        "FRONT",
        "LEFT",
        "RIGHT",
        "REAR"
      ],
      "description": "Optional coarse bearing hint for future directional RF workflows."
    },
    "confidence": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "bands": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "band_1_2": {
          "$ref": "#/$defs/bandStrength"
        },
        "band_2_4": {
          "$ref": "#/$defs/bandStrength"
        },
        "band_3_3": {
          "$ref": "#/$defs/bandStrength"
        },
        "band_5_8": {
          "$ref": "#/$defs/bandStrength"
        }
      }
    },
    "source": {
      "type": "string",
      "description": "Optional source label, such as ESP32_SIM or future detector adapter name."
    },
    "sequence": {
      "type": "integer",
      "minimum": 0,
      "description": "Optional monotonic packet sequence number from the bridge."
    }
  },
  "$defs": {
    "bandStrength": {
      "type": "string",
      "enum": [
        "LOW",
        "MED",
        "HIGH",
        "NONE"
      ]
    }
  }
}
